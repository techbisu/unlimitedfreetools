---
import BaseLayout from "../layouts/BaseLayout.astro";

interface Props {
  title?: string;
  description: string;
  canonical?: string;
  image?: string;
  structuredData?: Record<string, unknown> | Array<Record<string, unknown>>;
}

const {
  title = "UtilityHub",
  description,
  canonical,
  image,
  structuredData
} = Astro.props;
---

<BaseLayout
  title={title}
  description={description}
  canonical={canonical}
  image={image}
  structuredData={structuredData}
>
  <slot />
</BaseLayout>
