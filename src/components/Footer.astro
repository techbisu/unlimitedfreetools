---
import { popularToolSlugs, siteMeta, toolsBySlug } from "../data/tool-content.js";

const footerTools = popularToolSlugs.map((slug) => toolsBySlug[slug]).filter(Boolean);
---

<footer class="site-footer py-12">
  <div class="container-shell grid gap-10 lg:grid-cols-[1.3fr_1fr_1fr]">
    <div class="space-y-4">
      <p class="text-lg font-semibold text-[var(--ink)]">{siteMeta.name}</p>
      <p class="max-w-xl text-sm leading-7 text-[var(--muted)]">
        {siteMeta.description}
      </p>
      <p class="text-sm text-[var(--muted)]">
        No login, no account wall, and no daily limit across the main free tools.
      </p>
    </div>

    <div class="space-y-3">
      <p class="text-sm font-semibold uppercase tracking-[0.18em] text-[var(--muted)]">Popular Tools</p>
      {footerTools.map((tool) => (
        <a class="block text-sm text-[var(--muted)] transition hover:text-[var(--ink)]" href={`/${tool.slug}`}>
          {tool.name}
        </a>
      ))}
      <a class="block text-sm text-[var(--muted)] transition hover:text-[var(--ink)]" href="/blog">Blog</a>
    </div>

    <div class="space-y-3">
      <p class="text-sm font-semibold uppercase tracking-[0.18em] text-[var(--muted)]">Why People Use These Tools</p>
      <p class="text-sm leading-7 text-[var(--muted)]">
        Instant results, mobile friendly controls, custom downloads, unlimited free access, and clear feature options for everyday tasks.
      </p>
    </div>
  </div>
</footer>
