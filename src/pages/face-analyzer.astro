import FaceAnalyzerTool from "../components/tools/FaceAnalyzerTool.jsx";
import { pagesBySlug, toolsBySlug } from "../data/tool-content.js";

const tool = toolsBySlug["face-analyzer"];
const page = pagesBySlug["face-analyzer"];
