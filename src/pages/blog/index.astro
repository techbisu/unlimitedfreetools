---
import { getCollection } from "astro:content";
import BaseLayout from "../../layouts/BaseLayout.astro";
import AdBlock from "../../components/AdBlock.astro";
import BlogCard from "../../components/BlogCard.astro";
import PopularTools from "../../components/PopularTools.astro";
import LatestBlogPosts from "../../components/LatestBlogPosts.astro";

const posts = (await getCollection("blog", ({ data }) => !data.draft)).sort(
  (a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf()
);

const description =
  "Read practical guides about QR codes, image compression, PDF tasks, background removal, YouTube thumbnails, and everyday free online tools.";
---

<BaseLayout title="Blog" description={description} canonical="/blog">
  <section class="section-band">
    <div class="container-shell space-y-8">
      <div class="grid gap-6 lg:grid-cols-[minmax(0,1.2fr)_320px]">
        <div class="surface-panel-strong p-6 sm:p-8">
          <span class="eyebrow">Blog</span>
          <h1 class="mt-4 text-4xl font-semibold tracking-tight text-strong sm:text-5xl">Guides for QR, image, PDF, and utility tool workflows</h1>
          <p class="mt-4 max-w-3xl text-base leading-8 text-muted">
            Browse step-by-step articles about creating QR codes, reducing image and PDF file size, choosing better formats, improving page speed, and using free tools more effectively.
          </p>
        </div>

        <div class="surface-panel p-6">
          <p class="text-sm font-semibold uppercase tracking-[0.18em] text-soft">What you will find here</p>
          <ul class="mt-4 space-y-3 text-sm leading-7 text-muted">
            <li>Practical QR, PDF, and image workflows</li>
            <li>SEO-friendly publishing advice for faster pages</li>
            <li>Comparisons between formats like JPG, WebP, and AVIF</li>
            <li>How-to articles built around free online tools</li>
          </ul>
        </div>
      </div>

      <AdBlock variant="top" />
    </div>
  </section>

  <section class="section-band pt-0">
    <div class="container-shell">
      <div class="grid gap-5 md:grid-cols-2 xl:grid-cols-3">
        {posts.map((post) => (
          <BlogCard post={post} />
        ))}
      </div>
    </div>
  </section>

  <section class="section-band pt-0">
    <div class="container-shell">
      <AdBlock variant="mid" />
    </div>
  </section>

  <PopularTools />
  <LatestBlogPosts />
  <AdBlock variant="sticky" />
</BaseLayout>
