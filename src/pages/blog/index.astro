---
import { getCollection } from "astro:content";
import Layout from "../../components/Layout.astro";

const posts = (await getCollection("blog", ({ data }) => !data.draft)).sort(
  (a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf()
);

const description =
  "Browse image optimization articles covering image compression, AVIF, WebP, SEO, faster page speed, and practical publishing tips.";
---

<Layout title="Blog" description={description} canonical="/blog">
  <section class="container-shell pt-14 sm:pt-18">
    <div class="max-w-3xl">
      <span class="hero-chip">Blog</span>
      <h1 class="mt-4 font-display text-5xl font-semibold text-slate-950 sm:text-6xl">Image optimization blog</h1>
      <p class="mt-4 text-lg leading-8 text-slate-600">
        Explore practical guides about image compression, AVIF conversion, WebP, SEO, page speed, and image publishing strategies for growing websites.
      </p>
    </div>

    <div class="mt-12 grid gap-6 md:grid-cols-2 xl:grid-cols-3">
      {posts.map((post) => (
        <article class="surface-card rounded-[2rem] p-6">
          <p class="text-sm font-semibold uppercase tracking-[0.18em] text-slate-500">{post.data.category}</p>
          <h2 class="mt-3 font-display text-2xl font-semibold text-slate-950">
            <a class="transition hover:text-slate-700" href={`/blog/${post.id}/`}>
              {post.data.title}
            </a>
          </h2>
          <p class="mt-3 text-base leading-7 text-slate-600">{post.data.excerpt}</p>
          <div class="mt-5 flex items-center justify-between gap-3 text-sm text-slate-500">
            <time datetime={post.data.pubDate.toISOString()}>
              {post.data.pubDate.toLocaleDateString("en-US", { month: "short", day: "numeric", year: "numeric" })}
            </time>
            <a class="link-underline font-medium text-slate-950" href={`/blog/${post.id}/`}>
              Read article
            </a>
          </div>
        </article>
      ))}
    </div>
  </section>
</Layout>
