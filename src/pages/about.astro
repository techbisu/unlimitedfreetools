---
import Layout from "../components/Layout.astro";

const description =
  "Learn what Free Image Tools Online offers, who the tool is for, and how the platform is built for speed, simplicity, and publishing growth.";
---

<Layout title="About" description={description} canonical="/about">
  <section class="container-shell pt-14 sm:pt-18">
    <div class="mx-auto max-w-3xl">
      <span class="hero-chip">About the platform</span>
      <h1 class="mt-4 font-display text-5xl font-semibold text-slate-950 sm:text-6xl">About Free Image Tools Online</h1>
      <div class="surface-card prose-card mt-10 rounded-[2rem] p-8">
        <p>
          Free Image Tools Online is built to make image optimization simple, fast, and accessible. The goal is to give creators, bloggers, store owners, and marketers an easy way to compress and convert images without friction.
        </p>
        <p>
          The platform focuses on practical tasks that matter every day: shrinking image size, converting to modern formats like AVIF and WebP, checking before-and-after results, and downloading clean files that are ready for publishing.
        </p>
        <p>
          The site is also structured for long-term growth with evergreen blog content, policy pages, and scalable SEO foundations so it can grow into a strong image tools brand over time.
        </p>
      </div>
    </div>
  </section>
</Layout>
