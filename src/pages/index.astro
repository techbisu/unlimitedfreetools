---
import { getCollection } from "astro:content";
import ImageTool from "../components/ImageTool.astro";
import Layout from "../components/Layout.astro";

const description =
  "Free Image Tools Online is a fast, unlimited free image compressor and converter for JPG, PNG, WebP, and AVIF with instant previews and clean downloads.";
const featuredPosts = (await getCollection("blog", ({ data }) => !data.draft && data.featured)).sort(
  (a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf()
);
---

<Layout title="Free Image Tools Online" description={description} canonical="/">
  <section class="container-shell pt-14 sm:pt-20">
    <div class="grid gap-10 lg:grid-cols-[1.05fr_0.95fr] lg:items-center">
      <div class="space-y-6">
        <span class="hero-chip">Unlimited free image compressor and converter</span>
        <div class="space-y-4">
          <h1 class="font-display text-4xl font-semibold leading-tight text-slate-950 sm:text-6xl">
            Compress and convert images online in seconds.
          </h1>
          <p class="max-w-2xl text-base leading-7 text-slate-600 sm:text-lg sm:leading-8">
            Reduce file size, convert to AVIF, WebP, JPG, or PNG, compare before and after results, and download polished output with an easy mobile-friendly workflow.
          </p>
        </div>
        <div class="flex flex-col gap-3 sm:flex-row sm:flex-wrap">
          <a class="primary-button w-full sm:w-auto" href="#image-tool">Start Compressing</a>
          <a class="ghost-button w-full sm:w-auto" href="/tools/convert">Convert to AVIF, WebP, JPG, or PNG</a>
        </div>
        <div class="grid gap-3 sm:grid-cols-3">
          <div class="stat-card">
            <p class="text-sm text-slate-500">Pricing</p>
            <p class="mt-2 font-display text-2xl font-semibold text-slate-950">Free</p>
          </div>
          <div class="stat-card">
            <p class="text-sm text-slate-500">Limits</p>
            <p class="mt-2 font-display text-2xl font-semibold text-slate-950">Unlimited</p>
          </div>
          <div class="stat-card">
            <p class="text-sm text-slate-500">AVIF</p>
            <p class="mt-2 font-display text-2xl font-semibold text-slate-950">Lossless option</p>
          </div>
        </div>
      </div>

      <div class="surface-card rounded-[2rem] p-6">
        <div class="grid gap-4">
          <div class="preview-card">
            <div class="flex items-center justify-between border-b border-slate-900/8 px-5 py-4">
              <div>
                <p class="text-sm font-semibold text-slate-900">Built for everyday image optimization</p>
                <p class="mt-1 text-sm text-slate-500">Simple controls, instant results, and clean output for modern sites.</p>
              </div>
              <span class="pill">Fast mobile UX</span>
            </div>
            <div class="grid gap-4 p-5 sm:grid-cols-2">
              <div class="rounded-[1.5rem] bg-slate-950 p-5 text-white">
                <p class="text-sm text-white/70">Compression</p>
                <p class="mt-2 text-xl font-semibold">Smaller files without a messy workflow</p>
              </div>
              <div class="rounded-[1.5rem] bg-emerald-50 p-5 text-emerald-900">
                <p class="text-sm text-emerald-700">Conversion</p>
                <p class="mt-2 text-xl font-semibold">AVIF, WebP, JPG, and PNG in one tool</p>
              </div>
            </div>
          </div>

          <div class="grid gap-4 sm:grid-cols-2">
            <div class="stat-card">
              <p class="text-sm text-slate-500">Best for</p>
              <p class="mt-2 text-lg font-semibold text-slate-950">Blogs, ecommerce, landing pages, portfolios</p>
            </div>
            <div class="stat-card">
              <p class="text-sm text-slate-500">Top format</p>
              <p class="mt-2 text-lg font-semibold text-slate-950">AVIF with optional lossless export</p>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <section class="container-shell mt-14">
    <ImageTool
      initialMode="compress"
      title="Fast image compression and conversion for every device"
      description="Switch modes, tune the settings, compare the result, and download optimized output with an interface that works smoothly on mobile and desktop."
    />
  </section>

  <section class="container-shell mt-20">
    <div class="grid gap-6 lg:grid-cols-3">
      <article class="surface-card rounded-[2rem] p-6">
        <h2 class="font-display text-2xl font-semibold text-slate-950">Unlimited free compression</h2>
        <p class="mt-3 text-base leading-7 text-slate-600">
          Compress JPG, PNG, and WebP images as often as you need with smart settings, clear size comparisons, and instant downloads.
        </p>
      </article>
      <article class="surface-card rounded-[2rem] p-6">
        <h2 class="font-display text-2xl font-semibold text-slate-950">AVIF, WebP, JPG, and PNG conversion</h2>
        <p class="mt-3 text-base leading-7 text-slate-600">
          Convert image files between the most useful web formats, including AVIF with a lossless option for quality-focused exports.
        </p>
      </article>
      <article class="surface-card rounded-[2rem] p-6">
        <h2 class="font-display text-2xl font-semibold text-slate-950">SEO-ready content structure</h2>
        <p class="mt-3 text-base leading-7 text-slate-600">
          Category pages, article pages, metadata, privacy content, and an expanding blog library make the site ready for long-term organic growth.
        </p>
      </article>
    </div>
  </section>

  <section class="container-shell mt-20">
    <div class="flex flex-col gap-8 lg:flex-row lg:items-end lg:justify-between">
      <div>
        <span class="hero-chip">Image SEO and optimization blog</span>
        <h2 class="mt-4 font-display text-4xl font-semibold text-slate-950">Helpful guides for publishers and site owners</h2>
      </div>
      <a class="ghost-button" href="/blog">Browse all articles</a>
    </div>

    <div class="mt-8 grid gap-6 md:grid-cols-2">
      {featuredPosts.slice(0, 2).map((post) => (
        <article class="surface-card rounded-[2rem] p-6">
          <p class="text-sm font-semibold uppercase tracking-[0.18em] text-slate-500">{post.data.category}</p>
          <h3 class="mt-3 font-display text-2xl font-semibold text-slate-950">{post.data.title}</h3>
          <p class="mt-3 text-base leading-7 text-slate-600">
            {post.data.excerpt}
          </p>
          <a class="link-underline mt-4 inline-block font-medium text-slate-950" href={`/blog/${post.id}/`}>
            Read article
          </a>
        </article>
      ))}
    </div>
  </section>
</Layout>
