---
import BaseLayout from "../layouts/BaseLayout.astro";
import AdBlock from "../components/AdBlock.astro";
import FAQSection from "../components/FAQSection.astro";
import SEOSection from "../components/SEOSection.astro";
import PopularTools from "../components/PopularTools.astro";
import LatestBlogPosts from "../components/LatestBlogPosts.astro";
import ToolCard from "../components/ToolCard.astro";
import { homeContent, toolList } from "../data/tool-content.js";
---

<BaseLayout
  title={homeContent.metaTitle}
  description={homeContent.metaDescription}
  canonical="/"
  faqItems={homeContent.faqs}
>
  <section class="section-band">
    <div class="container-shell space-y-8">
      <div class="grid gap-6 lg:grid-cols-[minmax(0,1.2fr)_320px]">
        <div class="surface-panel-strong p-6 sm:p-8">
          <span class="eyebrow">Free Online Tools</span>
          <h1 class="mt-4 max-w-4xl text-4xl font-semibold tracking-tight text-strong sm:text-5xl">
            {homeContent.h1}
          </h1>
          <p class="mt-4 max-w-3xl text-base leading-8 text-muted">
            {homeContent.intro}
          </p>
          <div class="mt-6 flex flex-wrap gap-3">
            <a class="btn-primary" href="/qr-code-generator">Create QR Code</a>
            <a class="btn-secondary" href="/image-compressor">Compress Image</a>
          </div>
        </div>

        <div class="surface-panel p-6">
          <p class="text-sm font-semibold uppercase tracking-[0.18em] text-soft">Why users stay on the site</p>
          <ul class="mt-4 space-y-3 text-sm leading-7 text-muted">
            <li>No login or signup required</li>
            <li>Unlimited free tools with fast results</li>
            <li>Simple download and copy actions</li>
            <li>Clean mobile friendly tool pages</li>
          </ul>
        </div>
      </div>

      <AdBlock variant="top" />
    </div>
  </section>

  <section class="section-band pt-0">
    <div class="container-shell">
      <div class="grid gap-5 md:grid-cols-2 xl:grid-cols-3">
        {toolList.map((tool) => (
          <ToolCard href={`/${tool.slug}`} title={tool.name} category={tool.category} description={tool.description} />
        ))}
      </div>
    </div>
  </section>

  <section class="section-band pt-0">
    <div class="container-shell">
      <div class="surface-panel p-6 sm:p-8">
        <div class="grid gap-6 lg:grid-cols-3">
          <div>
            <p class="text-sm font-semibold uppercase tracking-[0.18em] text-soft">No Login</p>
            <p class="mt-3 text-xl font-semibold text-strong">Start using every tool instantly.</p>
          </div>
          <div>
            <p class="text-sm font-semibold uppercase tracking-[0.18em] text-soft">Unlimited Use</p>
            <p class="mt-3 text-xl font-semibold text-strong">Create, compress, format, and convert without daily caps.</p>
          </div>
          <div>
            <p class="text-sm font-semibold uppercase tracking-[0.18em] text-soft">Popular Features</p>
            <p class="mt-3 text-xl font-semibold text-strong">Logo QR codes, WebP and AVIF conversion, strong passwords, JSON cleanup, and fast unit results.</p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <section class="section-band pt-0">
    <div class="container-shell">
      <AdBlock variant="mid" />
    </div>
  </section>

  <PopularTools title="Popular free tools people open first" />
  <LatestBlogPosts />
  <SEOSection heading={homeContent.seoHeading} paragraphs={homeContent.seoParagraphs} />
  <FAQSection items={homeContent.faqs} />
  <AdBlock variant="sticky" />
</BaseLayout>
