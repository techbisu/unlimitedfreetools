---
import Layout from "../components/Layout.astro";

const description =
  "Contact Free Image Tools Online for support, partnerships, advertising questions, or product feedback.";
---

<Layout title="Contact" description={description} canonical="/contact">
  <section class="container-shell pt-14 sm:pt-18">
    <div class="mx-auto max-w-3xl">
      <span class="hero-chip">Contact</span>
      <h1 class="mt-4 font-display text-5xl font-semibold text-slate-950 sm:text-6xl">Contact</h1>
      <div class="surface-card prose-card mt-10 rounded-[2rem] p-8">
        <p>
          For support, partnerships, or advertising questions, use your launch address here before going live:
          <a class="link-underline font-medium text-slate-950" href="mailto:hello@freeimagetoolsonline.com"> hello@freeimagetoolsonline.com</a>.
        </p>
        <p>
          Keep this page updated with a real contact method, business information, and response details that match your production brand.
        </p>
      </div>
    </div>
  </section>
</Layout>
