---
import ImageTool from "../../components/ImageTool.astro";
import Layout from "../../components/Layout.astro";

const description =
  "Convert images to AVIF, WebP, JPG, or PNG with fast previews, unlimited free downloads, and a lossless AVIF option.";
---

<Layout title="Convert Images Online" description={description} canonical="/tools/convert">
  <section class="container-shell pt-14 sm:pt-18">
    <div class="max-w-3xl">
      <span class="hero-chip">Free image format conversion</span>
      <h1 class="mt-4 font-display text-4xl font-semibold text-slate-950 sm:text-6xl">Convert images online</h1>
      <p class="mt-4 text-base leading-7 text-slate-600 sm:text-lg sm:leading-8">
        Convert JPG, PNG, and WebP images into modern web formats, including AVIF with a lossless export option for high-quality output.
      </p>
    </div>
  </section>

  <section class="container-shell mt-12">
    <ImageTool
      initialMode="convert"
      title="Convert images to AVIF, WebP, JPG, or PNG"
      description="Choose the output format, preview the result, enable lossless AVIF when needed, and download clean converted files with a fast mobile-friendly flow."
    />
  </section>
</Layout>
